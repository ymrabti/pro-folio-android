default_platform(:android)

platform :android do

  desc "Deploy Kotlin Android App to Production"
  lane :production do

    # Find the AAB built by the CI Gradle step
    aab_path = Dir.glob("app/build/outputs/bundle/release/*.aab").first
    UI.user_error!("No AAB found in app/build/outputs/bundle/release/") unless aab_path
    UI.message("Uploading AAB: #{aab_path}")

    # Upload to Play Store
    upload_to_play_store(
      track: "production",
      aab: aab_path,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )

  end
end