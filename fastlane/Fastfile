default_platform(:android)

platform :android do

  desc "Deploy Kotlin Android App to Production"
  lane :production do

    # Build the release AAB
    gradle(
      task: "bundle",
      build_type: "Release"
    )

    # Use the path set by the gradle() action
    aab_path = Actions.lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH]
    UI.user_error!("No AAB found after gradle build") unless aab_path
    UI.message("Uploading AAB: #{aab_path}")

    # Upload to Play Store
    upload_to_play_store(
      track: "production",
      aab: aab_path,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )

  end
end